# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# OpenAI API (for AI code generation)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Pinata IPFS (for metadata uploads)
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_API_SECRET=YOUR_PINATA_API_SECRET

# Blockchain RPC URLs
POLYGON_AMOY_RPC_URL=https://polygon-amoy.infura.io/v3/YOUR_INFURA_PROJECT_ID
POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
INFURA_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
INFURA_MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Contract Addresses
MARKETPLACE_FACTORY_ADDRESS=0x...
RWATOKENIZER_ADDRESS=0x...

# Wallet (for deployments only)
DEPLOYER_PRIVATE_KEY=YOUR_PRIVATE_KEY
