# Environment Variables Example File for Frontend

# General
NODE_ENV=development

# API URL for the backend
VITE_API_URL=http://localhost:5000

# Wallet connection settings
VITE_WALLET_CONNECT_PROJECT_ID=YOUR_WALLET_CONNECT_PROJECT_ID

# Privy App ID for authentication
VITE_PRIVY_APP_ID=YOUR_PRIVY_APP_ID

# OpenAI API key for AI integrations (if applicable)
VITE_OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# IPFS configuration (if applicable)
VITE_IPFS_PROJECT_ID=YOUR_IPFS_PROJECT_ID
VITE_IPFS_PROJECT_SECRET=YOUR_IPFS_PROJECT_SECRET
